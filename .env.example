DATABASE_URL=postgresql://postgres:postgres@localhost:5432/be_an_ai_engineer

# Resend Email Service Settings (Optional for dry-run)
RESEND_API_KEY=

# Local Hermes LLM Proxy Settings (Optional, defaults to localhost:3000)
HERMES_HOST=127.0.0.1
HERMES_PORT=3000

# Vertex AI Search signal discovery
VERTEX_SEARCH_ENABLED=false
VERTEX_SEARCH_PROD_MODE=false
VERTEX_SEARCH_API_KEY=
VERTEX_SEARCH_PROJECT_ID=
VERTEX_SEARCH_LOCATION=global
VERTEX_SEARCH_ENGINE_ID=
VERTEX_SEARCH_SERVING_CONFIG_ID=default_search
VERTEX_SEARCH_QUOTA_STATE_FILE=_bmad-output/implementation-artifacts/vertex-search-quota-state.json
VERTEX_SEARCH_TEST_MONTHLY_CAP=100
VERTEX_SEARCH_TEST_DAILY_CAP=10
VERTEX_SEARCH_TEST_MAX_QUERIES_PER_RUN=3
VERTEX_SEARCH_PROD_MONTHLY_CAP=8000
VERTEX_SEARCH_PROD_DAILY_CAP=300
VERTEX_SEARCH_PROD_MAX_QUERIES_PER_RUN=100

# Wellfound signal discovery
WELLFOUND_DISCOVERY_ENABLED=false
WELLFOUND_IMPORT_FILE=
WELLFOUND_AUTO_EXTRACT_ENABLED=false
WELLFOUND_MAX_PAGES_PER_RUN=5
WELLFOUND_REQUEST_DELAY_SECONDS=5.0

# Common Crawl ATS source discovery
COMMON_CRAWL_DISCOVERY_ENABLED=false
COMMON_CRAWL_CRAWL_IDS=
COMMON_CRAWL_MAX_CRAWLS=1
COMMON_CRAWL_MAX_RECORDS_PER_PATTERN=25
COMMON_CRAWL_TOTAL_RECORD_CAP=100
COMMON_CRAWL_REQUEST_TIMEOUT_SECONDS=5.0
COMMON_CRAWL_REQUEST_DELAY_SECONDS=1.0
COMMON_CRAWL_MAX_RESPONSE_BYTES=500000

# YC company signal discovery
YC_COMPANY_DISCOVERY_ENABLED=false
YC_COMPANY_CATEGORIES=ai,developer-tools,infrastructure,data-engineering,databases,open-source,search
YC_COMPANY_IMPORT_FILE=
YC_COMPANY_MAX_COMPANIES_PER_CATEGORY=25
YC_COMPANY_MAX_TOTAL_COMPANIES=100
YC_COMPANY_REQUEST_TIMEOUT_SECONDS=5.0
YC_COMPANY_MAX_RESPONSE_BYTES=500000

# VC portfolio company signal discovery
VC_PORTFOLIO_DISCOVERY_ENABLED=false
VC_PORTFOLIO_IMPORT_FILE=
VC_PORTFOLIO_TARGETS_JSON=
VC_PORTFOLIO_MAX_COMPANIES_PER_TARGET=50
VC_PORTFOLIO_REQUEST_TIMEOUT_SECONDS=5.0
VC_PORTFOLIO_MAX_RESPONSE_BYTES=500000

# GitHub organization signal discovery
GITHUB_ORG_DISCOVERY_ENABLED=false
GITHUB_ORG_TOKEN=
GITHUB_ORG_TOPICS=llm,rag,vector-database,mlops,agents,fastapi,developer-tools,data-platform,evals
GITHUB_ORG_QUERIES=llm,rag,vector-database,mlops,agents,fastapi,developer-tools,data-platform,evals
GITHUB_ORG_MAX_SEARCH_QUERIES=6
GITHUB_ORG_MAX_PAGES_PER_QUERY=1
GITHUB_ORG_MAX_REPOS_PER_QUERY=10
GITHUB_ORG_MAX_ORGS_PER_RUN=25
GITHUB_ORG_MAX_ORGANIZATION_METADATA_FETCHES=10
GITHUB_ORG_MAX_README_FETCHES_PER_RUN=10
GITHUB_ORG_REQUEST_TIMEOUT_SECONDS=5.0
GITHUB_ORG_REQUEST_DELAY_SECONDS=1.0
GITHUB_ORG_MAX_RESPONSE_BYTES=500000

# Reddit hiring signal discovery
REDDIT_HIRING_DISCOVERY_ENABLED=false
REDDIT_HIRING_CLIENT_ID=
REDDIT_HIRING_CLIENT_SECRET=
REDDIT_HIRING_ACCESS_TOKEN=
REDDIT_HIRING_USER_AGENT=be-an-ai-engineer-source-discovery/1.0
REDDIT_HIRING_ALLOW_UNAUTHENTICATED=false
REDDIT_HIRING_SUBREDDITS=MachineLearningJobs,PythonJobs,forhire,remotepython
REDDIT_HIRING_SEARCH_TERMS=hiring,AI Engineer,LLM,RAG,Python,FastAPI,backend,remote
REDDIT_HIRING_MAX_PAGES_PER_QUERY=1
REDDIT_HIRING_MAX_POSTS_PER_QUERY=10
REDDIT_HIRING_MAX_POSTS_PER_RUN=50
REDDIT_HIRING_REQUEST_TIMEOUT_SECONDS=5.0
REDDIT_HIRING_REQUEST_DELAY_SECONDS=1.0
REDDIT_HIRING_MAX_RESPONSE_BYTES=500000
REDDIT_HIRING_DEFAULT_CONFIDENCE=0.25
REDDIT_HIRING_STRONG_SIGNAL_CONFIDENCE=0.4

# Discovery yield and freshness reporting
DISCOVERY_STALE_SOURCE_DAYS=30
DISCOVERY_REPEATED_REJECTION_WINDOW_DAYS=30
DISCOVERY_REPEATED_REJECTION_COUNT=3
DISCOVERY_HIGH_YIELD_MIN_VALIDATED_SOURCES=2
DISCOVERY_MAX_COMPANY_SIGNALS_PER_RUN=250
DISCOVERY_MAX_COMPANY_RESOLUTIONS_PER_RUN=100
